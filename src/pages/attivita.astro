---
import Layout from '../layouts/Layout.astro';
import { fetchCollection } from '../lib/directus';
import { mdInline } from '../lib/markdown';
import type { Attivita, Evento } from '../lib/types';

const adesso = new Date().toISOString();

const [attivita, prossimi] = await Promise.all([
  fetchCollection<Attivita>('attivita', { sort: 'sort' }),
  // evento collegato a un'attività più vicino in calendario: serve a marcare
  // una sola tessera con l'adesivo "Prossimo appuntamento"
  fetchCollection<Evento>('eventi', {
    fields: 'attivita_collegata,data_inizio',
    filter: {
      attivita_collegata: { _nnull: true },
      data_inizio: { _gte: adesso },
    },
    sort: 'data_inizio',
    limit: 1,
  }),
]);

const attivitaPiuVicina = prossimi[0]?.attivita_collegata ?? null;

/*
 * Layout della pagina: ordine, colore, dimensione e disegno di ogni area,
 * per slug. Le 5 aree sono un insieme fisso (i sub-brand), quindi la
 * disposizione è definita qui e non dal sort di Directus.
 */
const LAYOUT = [
  { slug: 'gioco-di-ruolo',     colore: 't-vermillion', span: 'span-3', disegno: 'd20' },
  { slug: 'mondi-tra-le-righe', colore: 't-petrol',     span: 'span-3', disegno: 'libro' },
  { slug: 'boardgames',         colore: 't-cobalt',     span: 'span-4', disegno: 'meeple' },
  { slug: 'mana-vault',         colore: 't-navy',       span: 'span-2', disegno: 'carte' },
  { slug: 'mondi-darte',        colore: 't-orange',     span: 'span-2', disegno: 'matita' },
];

interface Tessera {
  colore: string;
  span: string;
  disegno: string;
  dato: Attivita;
}

const perSlug = new Map(attivita.filter((a) => a.slug).map((a) => [a.slug!, a]));
const tessere: Tessera[] = LAYOUT
  .map((l) => ({ ...l, dato: perSlug.get(l.slug) }))
  .filter((l): l is Tessera => l.dato !== undefined);

// eventuali aree non previste dal LAYOUT: in coda, con stile neutro
const slugNoti = new Set(LAYOUT.map((l) => l.slug));
const extra: Tessera[] = attivita
  .filter((a) => a.slug && !slugNoti.has(a.slug))
  .map((a) => ({ colore: 't-petrol', span: 'span-3', disegno: '', dato: a }));

const tutte = [...tessere, ...extra];

const SVG_ATTR =
  'viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round"';
const DISEGNI: Record<string, string> = {
  carte: `<svg ${SVG_ATTR}><rect x="22" y="30" width="36" height="50" rx="6" transform="rotate(-13 40 55)"/><rect x="44" y="24" width="36" height="50" rx="6" transform="rotate(11 62 49)"/></svg>`,
  d20: `<svg ${SVG_ATTR}><polygon points="50,14 83,33 83,67 50,86 17,67 17,33"/><path d="M17 33 50 52 83 33M50 52 50 86M17 67 50 52 83 67"/></svg>`,
  meeple: `<svg ${SVG_ATTR}><path d="M50 14c-8 0-14 6-14 15 0 4 2 8 5 10-9 3-16 9-22 17-3 4-1 8 4 8l16 1-6 20c-2 5 2 8 6 8h30c4 0 8-3 6-8l-6-20 16-1c5 0 7-4 4-8-6-8-13-14-22-17 3-2 5-6 5-10 0-9-6-15-14-15z"/></svg>`,
  matita: `<svg ${SVG_ATTR}><path d="M68 16 L84 32 L40 76 L22 82 L28 64 Z"/><path d="M28 64 L40 76"/></svg>`,
  libro: `<svg ${SVG_ATTR}><path d="M50 30C40 24 26 24 14 28L14 76C26 72 40 72 50 78C60 72 74 72 86 76L86 28C74 24 60 24 50 30Z"/><path d="M50 30L50 78"/></svg>`,
  lampadina: `<svg ${SVG_ATTR}><path d="M37 70C37 62 31 58 27 50 21 38 29 20 50 20 71 20 79 38 73 50 69 58 63 62 63 70Z"/><path d="M41 80 L59 80M45 88 L55 88"/></svg>`,
};
---

<Layout
  titolo="Le nostre attività"
  descrizione="Le aree di attività del Crocevia dei Mondi: gioco, lettura, arte, narrazione."
>
  <section class="hero">
    <span class="pip pip-a"></span><span class="pip pip-b"></span>
    <span class="pip pip-c"></span><span class="pip pip-d"></span>
    <div class="hero__in">
      <h1>Le nostre <span class="hl">attività</span></h1>
      <p class="lede">
        Le aree in cui ci muoviamo. Nascono dalle passioni dei soci e
        crescono con chi le porta avanti.
      </p>
    </div>
  </section>

  <section class="areas">
    {tutte.length === 0 ? (
      <p class="vuota">Stiamo mettendo in ordine le aree: torneranno qui a breve.</p>
    ) : (
      <div class="grid">
        {tutte.map((t) => (
          <a class:list={['tile', t.colore, t.span]} href={`/attivita/${t.dato.slug}/`}>
            {t.dato.cadenza && <span class="tile__tag">{t.dato.cadenza}</span>}
            {attivitaPiuVicina && t.dato.UUID === attivitaPiuVicina && (
              <span class="tile__next">Prossimo appuntamento</span>
            )}
            {DISEGNI[t.disegno] && (
              <span class="tile__art" aria-hidden="true" set:html={DISEGNI[t.disegno]} />
            )}
            {t.dato.nome_html ? (
              <h2 class="tile__name" set:html={t.dato.nome_html} />
            ) : (
              <h2 class="tile__name">{t.dato.nome}</h2>
            )}
            {t.dato.descrizione_breve && (
              <p class="tile__desc" set:html={mdInline(t.dato.descrizione_breve)} />
            )}
            <span class="tile__go">Scopri l'area →</span>
          </a>
        ))}

        <a class="tile t-cta span-3" href="/contatti/">
          <span class="tile__tag">Hai un'idea?</span>
          <span class="tile__art" aria-hidden="true" set:html={DISEGNI.lampadina} />
          <h2 class="tile__name">Suggeriscine altri</h2>
          <p class="tile__desc">
            Le nostre attività le ideano e le portano avanti i soci. Proponi la tua.
          </p>
          <span class="tile__go">Scrivici →</span>
        </a>
      </div>
    )}
  </section>

  <section class="band">
    <div class="band__in">
      <p>Ogni area è aperta a tutti: non serve esperienza, serve voglia di giocare insieme.</p>
    </div>
  </section>
</Layout>

<style>
  /* ---- hero a blocco pieno ---- */
  .hero {
    background: var(--cdm-petrol);
    color: var(--cdm-cream);
    position: relative;
    overflow: hidden;
  }
  .hero__in {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 84px var(--gutter) 80px;
    position: relative;
    z-index: 2;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 7vw, 5.4rem);
    font-weight: 800;
    line-height: 1.02;
    margin: 0;
    max-width: 14ch;
    color: var(--cdm-cream);
  }
  .hero h1 .hl { color: var(--cdm-orange-light); }
  .hero .lede {
    font-size: 1.25rem;
    margin-top: 20px;
    max-width: 46ch;
    color: color-mix(in srgb, var(--cdm-cream) 88%, transparent);
  }
  .pip { position: absolute; border-radius: 50%; z-index: 1; }
  .pip-a {
    width: 240px; height: 240px; top: -70px; right: 90px;
    border: 3px solid color-mix(in srgb, var(--cdm-orange-light) 40%, transparent);
  }
  .pip-b { width: 90px; height: 90px; background: var(--cdm-orange); top: 120px; right: 60px; }
  .pip-c { width: 46px; height: 46px; background: var(--cdm-orange-light); top: 240px; right: 230px; }
  .pip-d {
    width: 140px; height: 140px; bottom: -50px; left: 48%;
    border: 3px solid color-mix(in srgb, var(--cdm-cream) 18%, transparent);
  }

  /* ---- griglia tessere ---- */
  .areas {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 64px 64px 30px;
  }
  .vuota {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding: var(--space-8);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 22px;
  }
  .span-2 { grid-column: span 2; }
  .span-3 { grid-column: span 3; }
  .span-4 { grid-column: span 4; }

  .tile {
    border-radius: 22px;
    padding: 34px 30px 28px;
    display: flex;
    flex-direction: column;
    min-height: 300px;
    position: relative;
    text-decoration: none;
    transition: transform 0.15s ease;
  }
  .tile:hover { transform: translateY(-6px); }

  .tile__tag {
    position: absolute;
    top: -13px;
    left: 26px;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 13px;
    border-radius: 7px;
    transform: rotate(-5deg);
    box-shadow: 2px 3px 0 rgba(13, 30, 34, 0.3);
    z-index: 2;
  }
  .tile:nth-child(even) .tile__tag { transform: rotate(4deg); }

  .tile__next {
    position: absolute;
    top: 26px;
    left: 36px;
    background: #fff;
    color: var(--cdm-petrol);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 7px 12px;
    border-radius: 7px;
    transform: rotate(6deg);
    box-shadow: 2px 3px 0 rgba(13, 30, 34, 0.3);
    z-index: 3;
  }

  .tile__art {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 62px;
    height: 62px;
    opacity: 0.95;
  }
  .span-4 .tile__art { width: 82px; height: 82px; }
  .tile__art :global(svg) { display: block; width: 100%; height: 100%; }

  .tile__name {
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1.04;
    margin: auto 0 8px;
  }
  .tile__desc { font-size: 1.05rem; margin: 0; }
  .tile__go { margin-top: 18px; font-weight: 700; font-size: 1.05rem; }

  /* ---- varianti colore ---- */
  .t-petrol { background: var(--cdm-petrol); color: #fff; }
  .t-petrol .tile__tag { background: var(--cdm-orange); color: #fff; }
  .t-orange { background: var(--cdm-orange); color: #fff; }
  .t-orange .tile__tag { background: var(--cdm-petrol); color: #fff; }
  .t-navy { background: var(--cdm-navy); color: #fff; }
  .t-navy .tile__tag { background: var(--cdm-orange); color: #fff; }
  .t-cobalt { background: var(--cdm-cobalt); color: #fff; }
  .t-cobalt .tile__tag { background: var(--cdm-orange); color: #fff; }
  .t-vermillion { background: var(--cdm-vermillion); color: #fff; }
  .t-vermillion .tile__tag { background: var(--cdm-petrol); color: #fff; }
  .t-cta {
    background: transparent;
    border: 3px dashed var(--cdm-orange);
    color: var(--color-text);
  }
  .t-cta .tile__tag { background: var(--cdm-orange); color: #fff; }
  .t-cta .tile__name { color: var(--cdm-orange); }

  /* ---- fascia motivo gioco ---- */
  /* margin-bottom negativo: annulla il margin-top del footer, cosi' la
     fascia colorata ci si appoggia senza spazio vuoto in mezzo */
  .band {
    background: var(--cdm-orange-light);
    margin-top: 34px;
    margin-bottom: calc(-1 * var(--space-24));
  }
  .band__in {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 46px var(--gutter);
  }
  .band p {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.7rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #3c2113;
    margin: 0 auto;
    max-width: 44ch;
    text-align: center;
  }

  /* ---- responsivo ---- */
  @media (max-width: 820px) {
    .areas { padding-inline: 24px; }
    .grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin-inline: auto;
    }
    .span-2, .span-3, .span-4 { grid-column: auto; }
  }
</style>
