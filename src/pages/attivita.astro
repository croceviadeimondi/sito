---
import Layout from '../layouts/Layout.astro';
import IntestazionePagina from '../components/IntestazionePagina.astro';
import { fetchCollection } from '../lib/directus';
import type { Attivita } from '../lib/types';

const attivita = await fetchCollection<Attivita>('attivita', { sort: 'sort' });
---

<Layout
  titolo="Le nostre attività"
  descrizione="Le aree di attività del Crocevia dei Mondi: gioco, lettura, arte, narrazione."
>
  <IntestazionePagina
    titolo="Le nostre attività"
    sommario="Le aree in cui ci muoviamo. Nascono dalle passioni dei soci e crescono con chi le porta avanti."
  />

  <section class="section">
    <div class="container">
      <div class="ambiti">
        {attivita.length === 0 ? (
          <p class="sezione-vuota">
            Stiamo mettendo in ordine le aree: torneranno qui a breve.
          </p>
        ) : (
          attivita.map((a) => (
            <article class="ambito">
              {a.nome_html ? (
                <h2 class="ambito__nome" set:html={a.nome_html} />
              ) : (
                <h2 class="ambito__nome">{a.nome}</h2>
              )}
              <p class="ambito__descrizione">{a.descrizione_breve}</p>
            </article>
          ))
        )}

        <a class="ambito ambito--proposta" href="/contatti/">
          <h2 class="ambito__nome">Suggeriscilo tu</h2>
          <p class="ambito__descrizione">
            Le nostre attività sono ideate e realizzate dai soci.
            Hai un'idea che ancora non c'è? Proponila e portala avanti con noi.
          </p>
          <span class="ambito__freccia" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .ambiti {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .sezione-vuota {
    grid-column: 1 / -1;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding: var(--space-8);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .ambito {
    padding: var(--space-8);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .ambito--proposta {
    background: transparent;
    border-style: dashed;
    border-color: var(--color-accent);
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    transition: background-color 150ms ease, transform 150ms ease;
  }

  .ambito--proposta:hover {
    background: color-mix(in srgb, var(--cdm-orange) 5%, transparent);
    transform: translateY(-2px);
  }

  .ambito--proposta .ambito__nome {
    color: var(--color-accent);
  }

  .ambito__freccia {
    align-self: flex-end;
    font-size: var(--text-2xl);
    color: var(--color-accent);
    line-height: 1;
    margin-top: auto;
  }

  .ambito__nome {
    margin: 0;
    font-size: var(--text-2xl);
  }

  .ambito__descrizione {
    margin: 0;
  }
</style>
