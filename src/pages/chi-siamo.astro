---
import Layout from '../layouts/Layout.astro';
import { fetchCollection, assetUrl } from '../lib/directus';
import { immagine, SLOT } from '../lib/immagini';
import { formattaData } from '../lib/formato';
import type { MediaEsterno, DirettivoMembro } from '../lib/types';

const [mediaRecenti, direttivo, heroFoto, scuoleFoto] = await Promise.all([
  fetchCollection<MediaEsterno>('media_esterni', {
    pubblicato: false,
    filter: { add_to_parlano_di_noi: { _eq: true } },
    sort: '-data,-id',
    limit: 3,
  }),
  fetchCollection<DirettivoMembro>('direttivo_membri', {
    sort: 'sort,id',
  }),
  immagine(SLOT.chiSiamoHero, null, { larghezza: 1600 }),
  immagine(SLOT.chiSiamoScuole, null, { larghezza: 1200 }),
]);

function iniziali(nome: string): string {
  return nome
    .split(/\s+/)
    .map((p) => p.charAt(0))
    .join('')
    .slice(0, 2)
    .toUpperCase();
}

function etichettaTipo(tipo: string): string {
  switch (tipo) {
    case 'articolo': return 'Articolo';
    case 'video': return 'Video';
    case 'podcast': return 'Podcast';
    default: return tipo;
  }
}
---

<Layout
  titolo="Chi siamo"
  descrizione="Crocevia dei Mondi APS: chi siamo, la nostra missione e il direttivo."
>
  <section class="hero">
    <span class="pip pip-a"></span><span class="pip pip-b"></span>
    <span class="pip pip-c"></span><span class="pip pip-d"></span>
    <span class="pip pip-e"></span>
    <div class="hero__in">
      <h1>Chi siamo</h1>
      <p class="lede">
        Una comunità di persone che costruisce insieme. Il gioco è la nostra
        lingua, l'inclusione è la nostra pratica.
      </p>
    </div>
  </section>

  <section class="corpo">
    <div class="container container-narrow">

      {heroFoto && (
        <figure class="hero-foto">
          <img src={heroFoto.src} alt={heroFoto.alt} loading="eager" />
        </figure>
      )}

      <p class="intro">
        Il Crocevia dei Mondi è una <strong>comunità di persone che costruisce
        insieme</strong>. Crediamo che il potere creativo vive nelle relazioni
        tra persone, e che il gioco sia il mezzo più potente per accendere quel
        potere. Siamo radicati nel sud Italia, ma il nostro valore non è il
        territorio: è il <strong>modo di fare comunità</strong>: orizzontale,
        inclusivo, creativo. Un modo replicabile ovunque.
      </p>

      <hr class="separatore" />

      <h2 class="sez-titolo">I valori che ci tengono insieme</h2>

      <article class="valore valore--orange">
        <h3>Comunità consapevole e creativa</h3>
        <p>
          Crediamo in <strong>comunità che si costruiscono
          insieme</strong>. Una comunità consapevole conosce i suoi valori, i
          suoi confini, le sue responsabilità. Una comunità creativa genera
          idee, sperimenta, rischia, impara dagli errori. È lo spazio dove le
          idee nascono, dove le relazioni si approfondiscono, dove il lavoro
          diventa senso, non solo reddito.
        </p>
      </article>

      <article class="valore valore--petrol">
        <h3>Il gioco come lingua della comunità</h3>
        <p>
          Il gioco non è evasione. È il mezzo attraverso cui una comunità
          <strong>pensa insieme, immagina insieme, crea insieme</strong>.
          Quando le persone giocano, le barriere tra "esperti" e "principianti"
          cadono. Chiunque può proporre, sperimentare, fallire senza colpa. Nel
          gioco emerge la creatività di chi normalmente non ha voce.
        </p>
        <p>
          Per noi, il gioco è il linguaggio principale. Lo usiamo per
          conoscerci, per abbattere le difese, per inventare insieme. Dalle
          sessioni di gioco emergono idee concrete, progetti reali, alleanze
          che durano nel tempo. E quando affrontiamo questioni gravi - come
          l'inclusione, la giustizia, il lavoro - continuiamo a parlarle
          attraverso il gioco, perché il gioco non toglie serietà, la rende
          accessibile.
        </p>
      </article>

      {scuoleFoto && (
        <figure class="foto-manifesto">
          <img src={scuoleFoto.src} alt={scuoleFoto.alt} loading="lazy" />
        </figure>
      )}

      <article class="valore valore--cobalt">
        <h3>Orizzontalità radicale e autonomia diffusa</h3>
        <p>
          Rifiutiamo le gerarchie come forma di controllo. Non perché neghiamo
          che alcune persone abbiano più esperienza di altre, ma l'esperienza
          non deve tradursi in <strong>potere</strong>, deve tradursi in
          <strong>facilitazione</strong>.
        </p>
        <p>
          Crediamo che ogni persona sia capace di portare avanti idee e
          progetti con il supporto di chi ha esperienza, non il permesso di chi
          ha autorità. La proposta di un'idea non richiede autorizzazione
          gerarchica: richiede chiarezza, ascolto, e la volontà di imparare
          insieme.
        </p>
        <p>
          Questo non significa che tutto è sempre votazione democratica.
          Significa che organizziamo il potere in modo che nessuno ne abbia
          troppo, nessuno troppo poco, che l'errore è parte del processo di
          apprendimento, non causa di esclusione.
        </p>
      </article>

      <article class="valore valore--vermillion">
        <h3>Inclusione come pratica, non dichiarazione</h3>
        <p>
          La diversità è il fondamento della nostra creatività. Ogni
          differenza di background, abilità, prospettiva, identità o lingua,
          rende la comunità più forte, più consapevole, più inventiva.
        </p>
        <p>
          L'inclusione è una pratica quotidiana, a volte scomoda, che implica
          abbattere barriere fisiche, economiche, culturali, linguistiche
          all'ingresso. Significa ascoltare attivamente chi viene da posizioni
          marginalizzate, cercare attivamente le voci che non sentiamo,
          lavorare su noi stessi per riconoscere e disimparare i pregiudizi
          che portiamo addosso.
        </p>
      </article>

      <blockquote class="chiusura">
        Insieme, formano un ecosistema: uno spazio dove le persone si incontrano
        come uguali, pensano insieme attraverso il gioco, decidono senza
        gerarchie, e nessuno viene lasciato fuori.
      </blockquote>

      <h2 class="sez-titolo">Letteralmente noi</h2>
      {direttivo.length === 0 ? (
        <p>
          Le facce dietro all'associazione: direttivo, soci, collaboratori.
          I profili saranno pubblicati a breve.
        </p>
      ) : (
        <ul role="list" class="direttivo">
          {direttivo.map((m) => {
            const photo = assetUrl(m.photo);
            return (
              <li class="membro">
                <div class="membro__foto">
                  {photo ? (
                    <img src={photo} alt={m.name} loading="lazy" />
                  ) : (
                    <span class="membro__iniziali" aria-hidden="true">{iniziali(m.name)}</span>
                  )}
                </div>
                <p class="membro__ruolo">{m.role}</p>
                {m.nickname ? (
                  <>
                    <h3 class="membro__nickname">{m.nickname}</h3>
                    <p class="membro__nome">{m.name}</p>
                  </>
                ) : (
                  <h3 class="membro__nickname">{m.name}</h3>
                )}
                {m.bio && <p class="membro__bio">{m.bio}</p>}
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>

  {mediaRecenti.length > 0 && (
    <section class="section section--blocco">
      <div class="container container-narrow">
        <header class="parlano__head">
          <h2>Parlano di noi</h2>
          <a href="/parlano-di-noi/" class="parlano__link">Tutta la rassegna →</a>
        </header>
        <ul role="list" class="parlano">
          {mediaRecenti.map((m) => (
            <li>
              <a href={m.url} rel="noopener" target="_blank" class="parlano__voce">
                <div class="parlano__meta">
                  <span class="parlano__tipo">{etichettaTipo(m.tipo)}</span>
                  {m.fonte && <span class="parlano__fonte">{m.fonte}</span>}
                  {m.data && (
                    <time class="parlano__data" datetime={m.data}>
                      {formattaData(m.data)}
                    </time>
                  )}
                </div>
                <span class="parlano__titolo">{m.titolo}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="recensisci">
    <div class="container recensisci__in">
      <p>E tu, che dici di noi?</p>
      <a class="recensisci__btn" href="/sedi/">Recensisci una delle nostre sedi →</a>
    </div>
  </section>
</Layout>

<style>
  /* ---- hero a blocco pieno ---- */
  .hero {
    background: var(--cdm-petrol);
    color: var(--cdm-cream);
    position: relative;
    overflow: hidden;
    /* contiene gli z-index interni: cosi' la foto del corpo, tirata su
       col margine negativo, resta sopra l'hero invece che dietro */
    isolation: isolate;
  }
  .hero__in {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 84px var(--gutter) 80px;
    position: relative;
    z-index: 2;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 7vw, 5.4rem);
    font-weight: 800;
    line-height: 1.02;
    margin: 0;
    color: var(--cdm-cream);
  }
  .hero .lede {
    font-size: 1.25rem;
    margin-top: 18px;
    max-width: 48ch;
    color: color-mix(in srgb, var(--cdm-cream) 88%, transparent);
  }
  /* "galassia" della pagina chi-siamo: una sua disposizione di pianeti */
  .pip { position: absolute; border-radius: 50%; z-index: 1; }
  .pip-a {
    width: 300px; height: 300px; top: -120px; right: -60px;
    border: 3px solid color-mix(in srgb, var(--cdm-cream) 16%, transparent);
  }
  .pip-b { width: 112px; height: 112px; background: var(--cdm-orange); top: 64px; right: 78px; }
  .pip-c { width: 38px; height: 38px; background: var(--cdm-orange-light); top: 52px; right: 232px; }
  .pip-d {
    width: 168px; height: 168px; top: 150px; right: 140px;
    border: 3px solid color-mix(in srgb, var(--cdm-orange-light) 38%, transparent);
  }
  .pip-e {
    width: 62px; height: 62px; bottom: 26px; right: 250px;
    background: color-mix(in srgb, var(--cdm-orange-light) 75%, transparent);
  }

  /* ---- corpo ---- */
  /* padding-top a 0 + z-index: la foto hero sconfina sopra la barra del
     titolo e ci resta davanti (l'hero e' posizionato, dipingerebbe dopo) */
  .corpo {
    padding-block: 0 var(--space-16);
    position: relative;
    z-index: 1;
  }

  .hero-foto {
    margin: calc(-1 * var(--space-16)) 0 var(--space-8);
  }
  .hero-foto img {
    display: block;
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .intro {
    font-size: var(--text-lg);
    line-height: 1.7;
    margin: 0;
  }

  .separatore {
    border: 0;
    border-top: 3px solid var(--cdm-orange);
    width: 4rem;
    margin: var(--space-12) 0;
  }

  .sez-titolo {
    margin-top: var(--space-12);
    margin-bottom: var(--space-8);
  }

  /* ---- valori: ognuno con un numero e un colore del logo ---- */
  .valore {
    border-left: 5px solid var(--c);
    padding-left: var(--space-6);
    margin-bottom: var(--space-12);
  }
  .valore--orange { --c: var(--cdm-orange); }
  .valore--petrol { --c: var(--cdm-petrol); }
  .valore--cobalt { --c: var(--cdm-cobalt); }
  .valore--vermillion { --c: var(--cdm-vermillion); }

  .valore h3 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-3);
    color: var(--c);
  }
  .valore p {
    margin-block: var(--space-3);
    line-height: 1.7;
  }
  .foto-manifesto {
    margin: var(--space-12) 0;
  }
  .foto-manifesto img {
    display: block;
    width: 100%;
    max-height: 380px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .chiusura {
    margin: var(--space-12) 0;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    background: var(--cdm-orange);
    color: #fff;
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.4;
  }

  /* ---- direttivo: carosello orizzontale che sfora ---- */
  .direttivo {
    list-style: none;
    margin-block: 0;
    margin-inline: calc(50% - 50vw);
    padding-block: 0 var(--space-3);
    padding-inline: var(--gutter);
    scroll-padding-inline-start: var(--gutter);
    display: flex;
    gap: var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x proximity;
    scrollbar-width: thin;
    scrollbar-color: var(--cdm-orange) transparent;
    -webkit-overflow-scrolling: touch;
  }
  .direttivo::-webkit-scrollbar { height: 8px; }
  .direttivo::-webkit-scrollbar-thumb {
    background: var(--cdm-orange);
    border-radius: var(--radius-pill);
  }

  .membro {
    flex: 0 0 max(170px, calc((100vw - 2 * var(--gutter) - 3 * var(--space-4)) / 4));
    scroll-snap-align: start;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
  }
  .membro__foto {
    width: 6rem;
    height: 6rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--cdm-petrol) 10%, transparent);
    overflow: hidden;
    display: grid;
    place-items: center;
    margin-bottom: var(--space-2);
  }
  .membro__foto img { width: 100%; height: 100%; object-fit: cover; }
  .membro__iniziali {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: var(--text-2xl);
    color: var(--cdm-orange);
  }
  .membro__ruolo {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--cdm-orange);
  }
  .membro__nickname {
    margin: var(--space-1) 0 0;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .membro__nome {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-muted);
  }
  .membro__bio {
    margin: var(--space-3) 0 0;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  /* ---- parlano di noi: blocco di colore pieno ---- */
  .section--blocco {
    background: var(--cdm-navy);
    color: #fff;
  }
  .parlano__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .parlano__head h2 { margin: 0; color: #fff; }
  .parlano__link {
    text-decoration: none;
    color: var(--cdm-orange-light);
    font-weight: 700;
    white-space: nowrap;
  }
  .parlano {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .parlano__voce {
    display: block;
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface);
    border-radius: 14px;
    text-decoration: none;
    color: var(--color-text);
    transition: transform 150ms ease;
  }
  .parlano__voce:hover { transform: translateY(-3px); }
  .parlano__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }
  .parlano__tipo {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    color: var(--cdm-orange);
  }
  .parlano__fonte { font-weight: 600; color: var(--color-text); }
  .parlano__data { margin-left: auto; }
  .parlano__titolo { font-weight: 500; }

  /* ---- CTA recensioni: fascia di chiusura appoggiata al footer ---- */
  .recensisci {
    background: var(--cdm-orange-light);
    margin-bottom: calc(-1 * var(--space-24));
  }
  .recensisci__in {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-8);
    padding-block: var(--space-12);
    text-align: center;
  }
  .recensisci__in p {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    color: #3c2113;
  }
  .recensisci__btn {
    background: var(--cdm-petrol);
    color: #fff;
    font-weight: 700;
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 150ms ease;
  }
  .recensisci__btn:hover { background: var(--cdm-navy); }

  @media (max-width: 540px) {
    .parlano__data { margin-left: 0; }
  }
</style>
