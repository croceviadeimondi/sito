---
import Layout from '../layouts/Layout.astro';
import IntestazionePagina from '../components/IntestazionePagina.astro';
import { fetchCollection, assetUrl } from '../lib/directus';
import { formattaData } from '../lib/formato';
import type { MediaEsterno, DirettivoMembro } from '../lib/types';

const [mediaRecenti, direttivo] = await Promise.all([
  fetchCollection<MediaEsterno>('media_esterni', {
    pubblicato: false,
    filter: { add_to_parlano_di_noi: { _eq: true } },
    sort: '-data,-id',
    limit: 3,
  }),
  fetchCollection<DirettivoMembro>('direttivo_membri', {
    sort: 'sort,id',
  }),
]);

function iniziali(nome: string): string {
  return nome
    .split(/\s+/)
    .map((p) => p.charAt(0))
    .join('')
    .slice(0, 2)
    .toUpperCase();
}

function etichettaTipo(tipo: string): string {
  switch (tipo) {
    case 'articolo': return 'Articolo';
    case 'video': return 'Video';
    case 'podcast': return 'Podcast';
    default: return tipo;
  }
}
---

<Layout
  titolo="Chi siamo"
  descrizione="Crocevia dei Mondi APS: chi siamo, la nostra missione e il direttivo."
>
  <IntestazionePagina
    titolo="Chi siamo"
    occhiello="L'associazione"
    sommario="Crocevia dei Mondi è un'Associazione di Promozione Sociale del Sud Italia. Crediamo che il gioco — da tavolo, di ruolo, narrativo — sia uno strumento serio per costruire comunità."
  />

  <section class="section">
    <div class="container container-narrow">
      <h2>La nostra missione</h2>
      <p class="paragrafo-grande">
        Mettiamo il gioco al servizio del legame sociale. Lavoriamo con scuole,
        biblioteche, centri di aggregazione e singole persone per creare spazi
        dove generazioni e culture diverse si incontrano davvero, intorno a un
        tavolo.
      </p>

      <h2>Cosa ci muove</h2>
      <p class="paragrafo-grande">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
        eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim
        ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut
        aliquip ex ea commodo consequat.
      </p>
      <ul class="elenco-valori">
        <li>
          <strong>Inclusività.</strong> Il gioco è un linguaggio comune che
          attraversa età, provenienze e abilità.
        </li>
        <li>
          <strong>Cura del territorio.</strong> Operiamo nel Sud Italia perché è
          il nostro terreno e il nostro impegno civile.
        </li>
        <li>
          <strong>Rigore narrativo.</strong> Crediamo nelle storie ben raccontate
          e nei meccanismi di gioco che producono significato.
        </li>
        <li>
          <strong>Trasparenza.</strong> Bilanci, attività e collaborazioni sono
          pubblici e consultabili.
        </li>
      </ul>

      <h2>Il direttivo</h2>
      {direttivo.length === 0 ? (
        <p>
          L'associazione è guidata da un direttivo eletto. I profili dei membri,
          con ruoli e brevi biografie, saranno pubblicati a breve.
        </p>
      ) : (
        <ul role="list" class="direttivo">
          {direttivo.map((m) => {
            const photo = assetUrl(m.photo);
            return (
              <li class="membro">
                <div class="membro__foto">
                  {photo ? (
                    <img src={photo} alt={m.name} loading="lazy" />
                  ) : (
                    <span class="membro__iniziali" aria-hidden="true">{iniziali(m.name)}</span>
                  )}
                </div>
                <h3 class="membro__nome">
                  {m.name}
                  {m.nickname && <span class="membro__nickname"> «{m.nickname}»</span>}
                </h3>
                <p class="membro__ruolo">{m.role}</p>
                {m.bio && <p class="membro__bio">{m.bio}</p>}
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>

  {mediaRecenti.length > 0 && (
    <section class="section section--alt">
      <div class="container container-narrow">
        <header class="parlano__head">
          <h2>Parlano di noi</h2>
          <a href="/parlano-di-noi/" class="parlano__link">Tutta la rassegna →</a>
        </header>
        <ul role="list" class="parlano">
          {mediaRecenti.map((m) => (
            <li>
              <a href={m.url} rel="noopener" target="_blank" class="parlano__voce">
                <div class="parlano__meta">
                  <span class="parlano__tipo">{etichettaTipo(m.tipo)}</span>
                  {m.fonte && <span class="parlano__fonte">{m.fonte}</span>}
                  {m.data && (
                    <time class="parlano__data" datetime={m.data}>
                      {formattaData(m.data)}
                    </time>
                  )}
                </div>
                <span class="parlano__titolo">{m.titolo}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
</Layout>

<style>
  .paragrafo-grande {
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
  }

  h2 {
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  h2:first-child {
    margin-top: 0;
  }

  .elenco-valori {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    display: grid;
    gap: var(--space-4);
  }

  .elenco-valori li {
    padding: var(--space-4) var(--space-6);
    border-left: 3px solid var(--color-accent);
    background: color-mix(in srgb, var(--cdm-orange) 6%, transparent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .direttivo {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .membro {
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
  }

  .membro__foto {
    width: 6rem;
    height: 6rem;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--cdm-petrol) 10%, transparent);
    overflow: hidden;
    display: grid;
    place-items: center;
    margin-bottom: var(--space-2);
  }

  .membro__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .membro__iniziali {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-2xl);
    color: var(--color-accent);
    letter-spacing: 0.04em;
  }

  .membro__nome {
    margin: 0;
    font-size: var(--text-lg);
  }

  .membro__nickname {
    font-weight: 400;
    color: var(--color-text-muted);
    font-style: italic;
    font-size: var(--text-base);
  }

  .membro__ruolo {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
  }

  .membro__bio {
    margin: var(--space-2) 0 0;
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .section--alt {
    background: color-mix(in srgb, var(--cdm-petrol) 6%, var(--color-bg));
  }

  .parlano__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .parlano__head h2 {
    margin: 0;
  }

  .parlano__link {
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 600;
  }

  .parlano {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .parlano__voce {
    display: block;
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 150ms ease;
  }

  .parlano__voce:hover {
    border-color: var(--color-accent);
  }

  .parlano__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .parlano__tipo {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    color: var(--color-accent);
  }

  .parlano__fonte {
    font-weight: 600;
    color: var(--color-text);
  }

  .parlano__data {
    margin-left: auto;
  }

  .parlano__titolo {
    font-weight: 500;
  }

  @media (max-width: 540px) {
    .parlano__data {
      margin-left: 0;
    }
  }
</style>
