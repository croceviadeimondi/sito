---
import Layout from '../../layouts/Layout.astro';
import IntestazionePagina from '../../components/IntestazionePagina.astro';
import CardEvento from '../../components/CardEvento.astro';
import { fetchCollection } from '../../lib/directus';
import { immagine } from '../../lib/immagini';
import { mdPlain, mdInline } from '../../lib/markdown';
import { formattaData } from '../../lib/formato';
import type { Attivita, Evento } from '../../lib/types';

export async function getStaticPaths() {
  const attivita = await fetchCollection<Attivita>('attivita', {
    sort: 'sort',
  });
  return attivita
    .filter((a) => a.slug)
    .map((a) => ({
      params: { slug: a.slug! },
      props: { attivita: a },
    }));
}

interface Props {
  attivita: Attivita;
}

const { attivita } = Astro.props;
// descrizione_breve è markdown: per il <meta> serve testo piatto
const descrizionePlain = mdPlain(attivita.descrizione_breve);
const adesso = new Date().toISOString();

const [prossimiAppuntamenti, archivio, fotoHero] = await Promise.all([
  // solo il primo evento futuro collegato: in pagina serve "il prossimo"
  fetchCollection<Evento>('eventi', {
    filter: {
      attivita_collegata: { _eq: attivita.UUID },
      data_inizio: { _gte: adesso },
    },
    sort: 'data_inizio',
    limit: 1,
  }),
  fetchCollection<Evento>('eventi', {
    filter: {
      attivita_collegata: { _eq: attivita.UUID },
      data_inizio: { _lt: adesso },
    },
    sort: '-data_inizio',
    limit: 6,
  }),
  immagine(`attivita/${attivita.slug}`, null, { larghezza: 1600 }),
]);

const prossimo = prossimiAppuntamenti[0] ?? null;
---

<Layout
  titolo={attivita.nome ?? 'Attività'}
  descrizione={descrizionePlain || `Un'area di attività del Crocevia dei Mondi APS`}
>
  <IntestazionePagina
    titolo={attivita.nome ?? 'Attività'}
    breadcrumb={{ href: '/attivita/', etichetta: '← Tutte le attività' }}
  />

  <section class="section section--hero">
    <div class="container container-narrow">
      {fotoHero && (
        <figure class="hero-attivita">
          <img src={fotoHero.src} alt={fotoHero.alt} loading="eager" />
        </figure>
      )}

      {attivita.nome_html && (
        <h2 class="nome-formattato" set:html={attivita.nome_html} />
      )}

      {attivita.descrizione_breve && (
        <p class="attivita-descrizione" set:html={mdInline(attivita.descrizione_breve)} />
      )}

      {(attivita.cadenza || prossimo) && (
        <dl class="attivita-info">
          {attivita.cadenza && (
            <div>
              <dt>Cadenza</dt>
              <dd>{attivita.cadenza}</dd>
            </div>
          )}
          {prossimo && (
            <div>
              <dt>Prossimo appuntamento</dt>
              <dd>
                <a href={`/eventi/${prossimo.slug}/`}>
                  {prossimo.titolo} · {formattaData(prossimo.data_inizio)}
                </a>
              </dd>
            </div>
          )}
        </dl>
      )}

      {archivio.length > 0 && (
        <>
          <h2>Appuntamenti recenti</h2>
          <ul role="list" class="griglia-card">
            {archivio.map((e) => (
              <li>
                <CardEvento evento={{ ...e, attivita_collegata: null }} />
              </li>
            ))}
          </ul>
        </>
      )}
    </div>
  </section>
</Layout>

<style>
  h2 {
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
  }
  h2:first-of-type {
    margin-top: var(--space-6);
  }

  /* la foto sconfina sopra la barra scura del titolo */
  .section--hero {
    padding-block: 0;
    position: relative;
    z-index: 1;
  }
  .hero-attivita {
    margin: calc(-1 * var(--space-16)) 0 var(--space-8);
  }
  .hero-attivita img {
    display: block;
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .nome-formattato {
    margin: var(--space-6) 0 0;
    font-size: var(--text-2xl);
    color: var(--color-text-muted);
  }

  .attivita-descrizione {
    font-size: var(--text-lg);
    line-height: 1.7;
    margin: var(--space-6) 0 var(--space-8);
  }

  /* cadenza + prossimo appuntamento */
  .attivita-info {
    margin: 0 0 var(--space-8);
    display: grid;
  }
  .attivita-info > div {
    display: grid;
    grid-template-columns: 13rem 1fr;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--color-border);
  }
  .attivita-info > div:first-child {
    border-top: 0;
  }
  .attivita-info dt {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-accent);
    align-self: center;
  }
  .attivita-info dd {
    margin: 0;
    font-size: var(--text-lg);
  }
  .attivita-info a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .attivita-info a:hover {
    text-decoration: underline;
  }

  .griglia-card {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8) var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (max-width: 540px) {
    .attivita-info > div {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
