---
import Layout from '../layouts/Layout.astro';
import IntestazionePagina from '../components/IntestazionePagina.astro';
import { fetchSingleton } from '../lib/directus';
import type { Impostazioni } from '../lib/types';

const impostazioni = await fetchSingleton<Impostazioni>('impostazioni');
const email = impostazioni?.email_principale ?? null;
const telefono = impostazioni?.telefono ?? null;
const denominazione = impostazioni?.denominazione_completa ?? 'Crocevia dei Mondi APS';

interface Social {
  etichetta: string;
  url: string;
}

const social: Social[] = [];
if (impostazioni?.instagram_handle) social.push({ etichetta: 'Instagram', url: impostazioni.instagram_handle });
if (impostazioni?.facebook_url) social.push({ etichetta: 'Facebook', url: impostazioni.facebook_url });
if (impostazioni?.linkedin_url) social.push({ etichetta: 'LinkedIn', url: impostazioni.linkedin_url });
if (impostazioni?.youtube_url) social.push({ etichetta: 'YouTube', url: impostazioni.youtube_url });

const gruppi = (impostazioni?.gruppi_chat ?? []).filter((g) => g?.nome && g?.url);
---

<Layout
  titolo="Contatti"
  descrizione="Come metterti in contatto con il Crocevia dei Mondi APS."
>
  <IntestazionePagina
    titolo="Contatti"
    occhiello="Parliamoci"
    sommario="Scrivici per proposte, collaborazioni, richieste di attività o per iscriverti come socio."
  />

  <section class="section">
    <div class="container container-narrow">

      <div class="dati-contatto">
        <h2>{denominazione}</h2>

        {email && (
          <p class="riga-contatto">
            <span class="riga-contatto__etichetta">Email</span>
            <a href={`mailto:${email}`} class="riga-contatto__valore">{email}</a>
          </p>
        )}

        {telefono && (
          <p class="riga-contatto">
            <span class="riga-contatto__etichetta">Telefono</span>
            <a href={`tel:${telefono.replace(/\s+/g, '')}`} class="riga-contatto__valore">{telefono}</a>
          </p>
        )}

        {social.length > 0 && (
          <p class="riga-contatto">
            <span class="riga-contatto__etichetta">Social</span>
            <span class="riga-contatto__valore lista-social">
              {social.map((s, i) => (
                <>
                  {i > 0 && <span aria-hidden="true"> · </span>}
                  <a href={s.url} rel="noopener" target="_blank">{s.etichetta}</a>
                </>
              ))}
            </span>
          </p>
        )}

        {gruppi.length > 0 && (
          <p class="riga-contatto">
            <span class="riga-contatto__etichetta">
              {gruppi.length === 1 ? 'Gruppo' : 'Gruppi'}
            </span>
            <span class="riga-contatto__valore lista-social">
              {gruppi.map((g, i) => (
                <>
                  {i > 0 && <span aria-hidden="true"> · </span>}
                  <a href={g.url} rel="noopener" target="_blank">{g.nome}</a>
                </>
              ))}
            </span>
          </p>
        )}

        {!email && !telefono && social.length === 0 && gruppi.length === 0 && (
          <p class="nota">I recapiti saranno pubblicati a breve.</p>
        )}
      </div>

      <section class="form-sezione">
        <h2>Scrivici direttamente</h2>
        <p class="form-intro">
          I tuoi dati arrivano nei nostri archivi e li usiamo solo per
          ricontattarti via email. Non li condividiamo con terzi.
        </p>

        <form class="form-contatti" id="form-contatti" novalidate>
          <div class="form-griglia">
            <div class="form-campo">
              <label for="form-nome">Nome</label>
              <input type="text" id="form-nome" name="nome" required maxlength="100" autocomplete="name" />
            </div>
            <div class="form-campo">
              <label for="form-email">Email</label>
              <input type="email" id="form-email" name="email" required maxlength="200" autocomplete="email" />
            </div>
          </div>
          <div class="form-campo">
            <label for="form-oggetto">Oggetto <span class="form-opt">(opzionale)</span></label>
            <input type="text" id="form-oggetto" name="oggetto" maxlength="200" />
          </div>
          <div class="form-campo">
            <label for="form-messaggio">Messaggio</label>
            <textarea id="form-messaggio" name="messaggio" required minlength="10" rows="6"></textarea>
          </div>

          <div class="form-honeypot" aria-hidden="true">
            <label for="form-website">Non compilare</label>
            <input type="text" id="form-website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="form-check">
            <input type="checkbox" id="form-privacy" name="accettazione_privacy" required />
            <label for="form-privacy">
              Acconsento al trattamento dei miei dati per essere ricontattato/a.
            </label>
          </div>

          <button type="submit" class="bottone form-submit">Invia messaggio</button>
          <p class="form-stato" role="status" aria-live="polite"></p>
        </form>
      </section>

    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('form-contatti') as HTMLFormElement | null;
  if (form) {
    const stato = form.querySelector('.form-stato') as HTMLElement;
    const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const cmsUrl = 'https://cms.croceviadeimondi.org/items/messaggi_contatto';

    const get = (n: string) =>
      (form.elements.namedItem(n) as HTMLInputElement | HTMLTextAreaElement | null)?.value ?? '';

    const setStato = (testo: string, cls: 'ok' | 'errore' | 'corso' | '') => {
      stato.textContent = testo;
      stato.className = 'form-stato' + (cls ? ` form-stato--${cls}` : '');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      if (get('website')) return; // honeypot: bot rilevato, fingiamo successo silenzioso

      submit.disabled = true;
      setStato('Invio in corso…', 'corso');

      try {
        const res = await fetch(cmsUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nome: get('nome'),
            email: get('email'),
            oggetto: get('oggetto') || null,
            messaggio: get('messaggio'),
            accettazione_privacy: true,
          }),
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        setStato('Grazie! Ti risponderemo via email il prima possibile.', 'ok');
        form.reset();
      } catch {
        setStato("Errore nell'invio. Riprova o scrivici direttamente via email.", 'errore');
      } finally {
        submit.disabled = false;
      }
    });
  }
</script>

<style>
  .dati-contatto {
    background: color-mix(in srgb, var(--cdm-petrol) 5%, var(--color-bg));
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-12);
  }

  .dati-contatto h2 {
    margin-bottom: var(--space-6);
  }

  .riga-contatto {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--space-4);
    padding-block: var(--space-3);
    border-top: 1px solid var(--color-border);
    margin: 0;
  }

  .riga-contatto:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .riga-contatto__etichetta {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    align-self: center;
  }

  .riga-contatto__valore {
    font-size: var(--text-lg);
    word-break: break-word;
  }

  .lista-social a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .lista-social a:hover {
    text-decoration: underline;
  }

  .nota {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .form-sezione h2 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-2xl);
  }

  .form-intro {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-6);
    max-width: 60ch;
  }

  .form-contatti {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .form-griglia {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 600px) {
    .form-griglia {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-campo {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-campo label {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
  }

  .form-opt {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-text-muted);
  }

  .form-campo input,
  .form-campo textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font: inherit;
    font-size: var(--text-base);
  }

  .form-campo input:focus-visible,
  .form-campo textarea:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
    border-color: var(--color-accent);
  }

  .form-campo textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-check {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .form-check input[type="checkbox"] {
    margin-top: 0.25em;
    width: 1.1em;
    height: 1.1em;
    accent-color: var(--color-accent);
    flex-shrink: 0;
  }

  .form-submit {
    align-self: flex-start;
  }

  .form-submit[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-stato {
    margin: 0;
    font-size: var(--text-sm);
    min-height: 1.2em;
  }

  .form-stato--corso { color: var(--color-text-muted); }
  .form-stato--ok    { color: #2a7a2a; font-weight: 600; }
  .form-stato--errore { color: #b03a2e; font-weight: 600; }

  @media (max-width: 540px) {
    .riga-contatto {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
