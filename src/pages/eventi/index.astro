---
import Layout from '../../layouts/Layout.astro';
import IntestazionePagina from '../../components/IntestazionePagina.astro';
import CardEvento from '../../components/CardEvento.astro';
import { fetchCollection } from '../../lib/directus';
import { immagine, SLOT } from '../../lib/immagini';
import type { Evento, Attivita } from '../../lib/types';

const [tutti, attivitaTutte, fotoHero] = await Promise.all([
  // Solo eventi una tantum: gli appuntamenti ricorrenti delle attività
  // restano sulle pagine /attivita/[slug] per non duplicare in lista
  fetchCollection<Evento>('eventi', {
    filter: { attivita_collegata: { _null: true } },
    sort: 'data_inizio',
  }),
  fetchCollection<Attivita>('attivita', { fields: 'UUID,slug', sort: 'sort' }),
  immagine(SLOT.eventiHero, null, { larghezza: 1800 }),
]);
const slugAttivita: Record<string, string> = {};
for (const a of attivitaTutte) {
  if (a.UUID && a.slug) slugAttivita[a.UUID] = a.slug;
}
const adesso = new Date().toISOString();

const futuri = tutti.filter((e) => e.data_inizio >= adesso);
const archivio = tutti
  .filter((e) => e.data_inizio < adesso)
  .reverse();
---

<Layout
  titolo="Eventi"
  descrizione="Tutti gli appuntamenti del Crocevia dei Mondi: prossimi eventi e archivio storico."
>
  <IntestazionePagina
    titolo="Eventi"
    occhiello="Calendario"
    sommario="Demo, tornei, gruppi di lettura, laboratori. Tutti gli appuntamenti aperti al pubblico - passati e futuri."
  />

  <section class="section section--hero">
    <div class="container">
      {fotoHero && (
        <figure class="foto-eventi">
          <img src={fotoHero.src} alt={fotoHero.alt} loading="lazy" />
        </figure>
      )}

      <p class="rimando-attivita">
        Cerchi gli appuntamenti ricorrenti (Mana Vault, Gioco di Ruolo, Board Games…)?
        <a href="/attivita/">Vedi le attività ricorrenti →</a>
      </p>

      <h2 class="lista__titolo">Prossimi appuntamenti</h2>
      {futuri.length === 0 ? (
        <p class="sezione-vuota">
          Nessun evento in calendario al momento. Torna a trovarci a breve.
        </p>
      ) : (
        <ul role="list" class="griglia-card">
          {futuri.map((evento) => (
            <li><CardEvento evento={evento} slugAttivita={slugAttivita} /></li>
          ))}
        </ul>
      )}
    </div>
  </section>

  {archivio.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <h2 class="lista__titolo">Archivio</h2>
        <ul role="list" class="griglia-card">
          {archivio.map((evento) => (
            <li><CardEvento evento={evento} slugAttivita={slugAttivita} /></li>
          ))}
        </ul>
      </div>
    </section>
  )}
</Layout>

<style>
  .lista__titolo {
    margin-bottom: var(--space-8);
  }

  /* Section dell'hero: niente padding-block, cosi' l'hero sconfina
     sopra la barra scura del titolo. */
  .section--hero {
    padding-block: 0;
  }

  .foto-eventi {
    margin: calc(-1 * var(--space-8)) 0 var(--space-8);
  }

  .foto-eventi img {
    display: block;
    width: 100%;
    max-height: 380px;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .rimando-attivita {
    margin: 0 0 var(--space-8);
    padding: var(--space-4) var(--space-6);
    background: color-mix(in srgb, var(--cdm-orange) 6%, transparent);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-text);
  }

  .rimando-attivita a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    margin-left: var(--space-2);
  }

  .section--alt {
    background: color-mix(in srgb, var(--cdm-petrol) 6%, var(--color-bg));
  }

  .sezione-vuota {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding: var(--space-8);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .griglia-card {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
