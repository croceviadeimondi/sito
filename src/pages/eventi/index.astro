---
import Layout from '../../layouts/Layout.astro';
import CardEvento from '../../components/CardEvento.astro';
import { fetchCollection } from '../../lib/directus';
import { immagine, SLOT } from '../../lib/immagini';
import type { Evento, Attivita } from '../../lib/types';

const [tutti, attivitaTutte, fotoHero] = await Promise.all([
  // Solo eventi una tantum: gli appuntamenti ricorrenti delle attività
  // restano sulle pagine /attivita/[slug] per non duplicare in lista
  fetchCollection<Evento>('eventi', {
    filter: { attivita_collegata: { _null: true } },
    sort: 'data_inizio',
  }),
  fetchCollection<Attivita>('attivita', { fields: 'UUID,slug', sort: 'sort' }),
  immagine(SLOT.eventiHero, null, { larghezza: 1800 }),
]);
const slugAttivita: Record<string, string> = {};
for (const a of attivitaTutte) {
  if (a.UUID && a.slug) slugAttivita[a.UUID] = a.slug;
}
const adesso = new Date().toISOString();

const futuri = tutti.filter((e) => e.data_inizio >= adesso);
const archivio = tutti
  .filter((e) => e.data_inizio < adesso)
  .reverse();
---

<Layout
  titolo="Eventi"
  descrizione="Tutti gli appuntamenti del Crocevia dei Mondi: prossimi eventi e archivio storico."
>
  <section class="hero">
    <span class="pip pip-a"></span><span class="pip pip-b"></span>
    <span class="pip pip-c"></span><span class="pip pip-d"></span>
    <span class="pip pip-e"></span>
    <div class="hero__in">
      <h1>Eventi</h1>
      <p class="lede">
        Demo, tornei, gruppi di lettura, laboratori. Tutti gli appuntamenti
        aperti al pubblico, passati e futuri.
      </p>
    </div>
  </section>

  <section class="corpo">
    <div class="container">
      {fotoHero && (
        <figure class="foto-eventi">
          <img src={fotoHero.src} alt={fotoHero.alt} loading="lazy" />
        </figure>
      )}

      <p class="rimando-attivita">
        Cerchi gli appuntamenti ricorrenti (Mana Vault, Gioco di Ruolo, Board Games…)?
        <a href="/attivita/">Vedi le attività ricorrenti →</a>
      </p>

      <h2 class="lista__titolo">Prossimi appuntamenti</h2>
      {futuri.length === 0 ? (
        <p class="sezione-vuota">
          Nessun evento in calendario al momento. Torna a trovarci a breve.
        </p>
      ) : (
        <ul role="list" class="griglia-card">
          {futuri.map((evento) => (
            <li><CardEvento evento={evento} slugAttivita={slugAttivita} /></li>
          ))}
        </ul>
      )}
    </div>
  </section>

  {archivio.length > 0 && (
    <section class="section section--blocco">
      <div class="container">
        <h2 class="lista__titolo">Archivio</h2>
        <ul role="list" class="griglia-card">
          {archivio.map((evento) => (
            <li><CardEvento evento={evento} slugAttivita={slugAttivita} /></li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="cta-banda">
    <div class="container cta-banda__in">
      <p>Vuoi collaborare o proporci un evento?</p>
      <a class="cta-banda__btn" href="/contatti/">Contattaci →</a>
    </div>
  </section>
</Layout>

<style>
  /* ---- hero a blocco pieno ---- */
  .hero {
    background: var(--cdm-petrol);
    color: var(--cdm-cream);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__in {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 84px var(--gutter) 80px;
    position: relative;
    z-index: 2;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 7vw, 5.4rem);
    font-weight: 800;
    line-height: 1.02;
    margin: 0;
    color: var(--cdm-cream);
  }
  .hero .lede {
    font-size: 1.25rem;
    margin-top: 18px;
    max-width: 48ch;
    color: color-mix(in srgb, var(--cdm-cream) 88%, transparent);
  }

  /* "galassia" della pagina eventi */
  .pip { position: absolute; border-radius: 50%; z-index: 1; }
  .pip-a {
    width: 210px; height: 210px; top: -66px; right: 280px;
    border: 3px solid color-mix(in srgb, var(--cdm-orange-light) 32%, transparent);
  }
  .pip-b { width: 150px; height: 150px; background: var(--cdm-orange); top: 24px; right: -54px; }
  .pip-c { width: 64px; height: 64px; background: var(--cdm-orange-light); top: 150px; right: 120px; }
  .pip-d { width: 34px; height: 34px; background: var(--cdm-orange-light); top: 58px; right: 92px; }
  .pip-e {
    width: 120px; height: 120px; bottom: -50px; right: 220px;
    border: 3px solid color-mix(in srgb, var(--cdm-cream) 14%, transparent);
  }

  /* ---- corpo: la foto sconfina sopra l'hero ---- */
  .corpo {
    padding-block: 0 var(--space-16);
    position: relative;
    z-index: 1;
  }
  .foto-eventi {
    margin: calc(-1 * var(--space-16)) 0 var(--space-8);
  }
  .foto-eventi img {
    display: block;
    width: 100%;
    max-height: 380px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .rimando-attivita {
    margin: 0 0 var(--space-12);
    padding: var(--space-4) var(--space-6);
    background: color-mix(in srgb, var(--cdm-orange) 8%, transparent);
    border-left: 4px solid var(--cdm-orange);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-text);
  }
  .rimando-attivita a {
    color: var(--cdm-orange);
    text-decoration: none;
    font-weight: 700;
    margin-left: var(--space-2);
  }

  .lista__titolo {
    margin-bottom: var(--space-8);
  }

  /* ---- archivio: blocco di colore pieno ---- */
  .section--blocco {
    background: var(--cdm-navy);
    color: #fff;
  }
  .section--blocco .lista__titolo { color: #fff; }

  .sezione-vuota {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding: var(--space-8);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .griglia-card {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-8) var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* fascia CTA di chiusura: si appoggia al footer (margin negativo) */
  .cta-banda {
    background: var(--cdm-orange-light);
    margin-bottom: calc(-1 * var(--space-24));
  }
  .cta-banda__in {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-8);
    padding-block: var(--space-12);
    text-align: center;
  }
  .cta-banda__in p {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    color: #3c2113;
  }
  .cta-banda__btn {
    background: var(--cdm-petrol);
    color: #fff;
    font-weight: 700;
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 150ms ease;
  }
  .cta-banda__btn:hover { background: var(--cdm-navy); }
</style>
