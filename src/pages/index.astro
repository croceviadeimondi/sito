---
import Layout from '../layouts/Layout.astro';
import CardEvento from '../components/CardEvento.astro';
import CardProgetto from '../components/CardProgetto.astro';
import { fetchCollection, assetUrl } from '../lib/directus';
import type { Evento, Progetto, Attivita } from '../lib/types';

interface FotoCaroselloItem {
  directus_files_id: string | null;
  eventi_id: { titolo: string; slug: string } | null;
}

const adesso = new Date().toISOString();

const [prossimiEventi, progettiVetrina, fotoCarosello, attivitaTutte] = await Promise.all([
  fetchCollection<Evento>('eventi', {
    filter: {
      data_inizio: { _gte: adesso },
      attivita_collegata: { _null: true },
    },
    sort: 'data_inizio',
    limit: 3,
  }),
  fetchCollection<Progetto>('progetti', {
    sort: 'sort',
    limit: 3,
  }),
  // Carosello home: solo foto della gallery flaggate `in_carosello_home`
  // sulla junction eventi_files. Espandiamo l'evento parent per ricavare
  // titolo (alt) e slug (link al dettaglio).
  fetchCollection<FotoCaroselloItem>('eventi_files', {
    fields: 'directus_files_id,eventi_id.titolo,eventi_id.slug',
    filter: { in_carosello_home: { _eq: true } },
    pubblicato: false,
    limit: 24,
  }),
  fetchCollection<Attivita>('attivita', { fields: 'UUID,slug', sort: 'sort' }),
]);

const slugAttivita: Record<string, string> = {};
for (const a of attivitaTutte) {
  if (a.UUID && a.slug) slugAttivita[a.UUID] = a.slug;
}

const fotoGallery = fotoCarosello
  .map((f) => {
    const url = assetUrl(f.directus_files_id);
    if (!url || !f.eventi_id) return null;
    return { url, titolo: f.eventi_id.titolo, slug: f.eventi_id.slug };
  })
  .filter((x): x is { url: string; titolo: string; slug: string } => x !== null);
---

<Layout
  titolo="Home"
  descrizione="Crocevia dei Mondi APS: il gioco come strumento sociale, mondi che si incontrano nel Sud Italia."
  headerGrande
>
    {fotoGallery.length > 0 && (
      <section class="banner-attivita" aria-label="Siamo stati qui">
        <p class="banner-attivita__etichetta">Siamo stati qui</p>
        <ul role="list" class="banner-attivita__lista">
          {fotoGallery.map((f) => (
            <li class="banner-attivita__slide">
              <a href={`/eventi/${f.slug}/`} class="banner-attivita__link">
                <img
                  src={`${f.url}?width=1600&height=720&fit=cover&format=jpg&quality=82`}
                  alt={f.titolo}
                  loading="lazy"
                />
                <div class="banner-attivita__overlay">
                  <h2 class="banner-attivita__nome">{f.titolo}</h2>
                </div>
              </a>
            </li>
          ))}
        </ul>
        {fotoGallery.length > 1 && (
          <div class="banner-attivita__dots" role="tablist" aria-label="Naviga le foto">
            {fotoGallery.map((f, i) => (
              <button
                type="button"
                class="banner-attivita__dot"
                data-slide-index={i}
                aria-label={`Vai alla foto ${i + 1}: ${f.titolo}`}
              ></button>
            ))}
          </div>
        )}
      </section>
    )}

  <section class="section">
    <div class="container">
      <header class="sezione-intestazione">
        <h2>Prossimi eventi</h2>
        <a href="/eventi/" class="sezione-intestazione__link">Tutti gli eventi →</a>
      </header>

      {prossimiEventi.length === 0 ? (
        <p class="sezione-vuota">
          Calendario in arrivo: appena pubblichiamo i prossimi appuntamenti li trovi qui.
        </p>
      ) : (
        <ul role="list" class="griglia-card">
          {prossimiEventi.map((evento) => (
            <li><CardEvento evento={evento} slugAttivita={slugAttivita} /></li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="sezione-intestazione">
        <h2>Progetti in vetrina</h2>
        <a href="/progetti/" class="sezione-intestazione__link">Tutti i progetti →</a>
      </header>

      {progettiVetrina.length === 0 ? (
        <p class="sezione-vuota">
          Stiamo preparando la vetrina dei progetti attivi e di quelli realizzati.
        </p>
      ) : (
        <ul role="list" class="griglia-card">
          {progettiVetrina.map((progetto) => (
            <li><CardProgetto progetto={progetto} /></li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>

<script>
  const banner = document.querySelector<HTMLElement>('.banner-attivita');
  if (banner) {
    const lista = banner.querySelector<HTMLElement>('.banner-attivita__lista');
    const slides = banner.querySelectorAll<HTMLElement>('.banner-attivita__slide');
    const dots = banner.querySelectorAll<HTMLButtonElement>('.banner-attivita__dot');

    if (lista && slides.length > 0 && dots.length === slides.length) {
      let idxCorrente = 0;
      const setActivo = (idx: number) => {
        idxCorrente = idx;
        dots.forEach((d, i) => d.classList.toggle('is-attivo', i === idx));
      };

      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
              const idx = Array.from(slides).indexOf(entry.target as HTMLElement);
              if (idx >= 0) setActivo(idx);
            }
          }
        },
        { root: lista, threshold: 0.5 },
      );
      slides.forEach((s) => io.observe(s));

      // Animazione custom per controllare la durata (il browser di default
      // è troppo veloce con behavior:'smooth')
      const DURATA_SCORRIMENTO = 900;
      let animFrame: number | null = null;
      const vaiA = (idx: number) => {
        const target = slides[idx].offsetLeft;
        const partenza = lista.scrollLeft;
        const distanza = target - partenza;
        if (Math.abs(distanza) < 1) return;
        if (animFrame !== null) cancelAnimationFrame(animFrame);
        const t0 = performance.now();
        const step = (now: number) => {
          const t = Math.min(1, (now - t0) / DURATA_SCORRIMENTO);
          const ease = 1 - Math.pow(1 - t, 3); // ease-out cubic
          lista.scrollLeft = partenza + distanza * ease;
          if (t < 1) animFrame = requestAnimationFrame(step);
          else animFrame = null;
        };
        animFrame = requestAnimationFrame(step);
      };

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          vaiA(i);
          pausa();
        });
      });

      setActivo(0);

      // Auto-advance ogni 6s (rispetta prefers-reduced-motion)
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      let intervalId: number | null = null;
      let timeoutRipresa: number | null = null;
      const INTERVALLO = 8000;
      const RIPRESA_DOPO = 14000;

      const start = () => {
        if (slides.length < 2 || reduceMotion.matches) return;
        stop();
        intervalId = window.setInterval(() => {
          vaiA((idxCorrente + 1) % slides.length);
        }, INTERVALLO);
      };
      const stop = () => {
        if (intervalId !== null) {
          clearInterval(intervalId);
          intervalId = null;
        }
      };
      const pausa = () => {
        stop();
        if (timeoutRipresa !== null) clearTimeout(timeoutRipresa);
        timeoutRipresa = window.setTimeout(start, RIPRESA_DOPO);
      };

      // Stop quando la tab non è visibile (risparmia risorse)
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stop();
        else start();
      });

      // L'utente che interagisce mette in pausa temporanea (no hover desktop:
      // l'autoplay deve continuare anche quando il mouse è sopra)
      lista.addEventListener('touchstart', pausa, { passive: true });
      lista.addEventListener('wheel', pausa, { passive: true });

      start();
    }
  }
</script>

<style>
  /* Banner full-width: foto curate (flag in_carosello_home) con CTA overlay.
     Click sulla slide -> dettaglio del singolo evento. */
  .banner-attivita {
    position: relative;
  }

  .banner-attivita__lista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    /* scrollbar nascosta: la navigazione avviene tramite i pallini sotto */
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .banner-attivita__lista::-webkit-scrollbar { display: none; }

  .banner-attivita__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  .banner-attivita__link {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 7;
    max-height: 70vh;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-on-dark);
    background: color-mix(in srgb, var(--cdm-petrol) 15%, transparent);
  }

  .banner-attivita__link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Inquadratura leggermente sopra la metà */
    object-position: center 35%;
    display: block;
  }

  .banner-attivita__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-12) var(--gutter) var(--space-10);
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--cdm-petrol) 55%, transparent) 0%,
      color-mix(in srgb, var(--cdm-petrol) 20%, transparent) 45%,
      transparent 90%
    );
  }

  /* Pallini di navigazione (top center) */
  .banner-attivita__dots {
    position: absolute;
    top: var(--space-4);
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    z-index: 2;
  }

  .banner-attivita__dot {
    width: 0.6rem;
    height: 0.6rem;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: background 200ms ease, transform 200ms ease;
  }

  .banner-attivita__dot:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  .banner-attivita__dot.is-attivo {
    background: rgba(255, 255, 255, 1);
    transform: scale(1.25);
  }

  .banner-attivita__etichetta {
    position: absolute;
    top: var(--space-4);
    left: var(--gutter);
    z-index: 2;
    margin: 0;
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent);
    color: var(--color-on-dark);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--cdm-petrol) 25%, transparent);
  }

  .banner-attivita__nome {
    margin: 0;
    font-size: var(--text-display);
    line-height: 1.05;
    color: var(--color-on-dark);
    text-shadow: 0 2px 12px color-mix(in srgb, var(--cdm-petrol) 60%, transparent);
  }

  @media (max-width: 640px) {
    .banner-attivita__link {
      aspect-ratio: 4 / 5;
    }
    .banner-attivita__nome {
      font-size: var(--text-2xl);
    }
    .banner-attivita__overlay {
      padding: var(--space-8) var(--space-4) var(--space-6);
    }
  }

  .section--alt {
    background: color-mix(in srgb, var(--cdm-petrol) 6%, var(--color-bg));
  }

  .sezione-intestazione {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .sezione-intestazione__link {
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 600;
  }

  .sezione-vuota {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding: var(--space-8);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .griglia-card {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
