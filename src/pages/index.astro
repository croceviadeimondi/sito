---
import Layout from '../layouts/Layout.astro';
import CardEvento from '../components/CardEvento.astro';
import CardProgetto from '../components/CardProgetto.astro';
import { fetchCollection, assetUrl } from '../lib/directus';
import type { Evento, Progetto, Attivita } from '../lib/types';

interface FotoCaroselloItem {
  directus_files_id: string | null;
  eventi_id: { titolo: string; slug: string } | null;
}

const adesso = new Date().toISOString();

const [prossimiEventi, progettiVetrina, heroEventi, fotoCarosello, attivitaTutte] = await Promise.all([
  fetchCollection<Evento>('eventi', {
    filter: { data_inizio: { _gte: adesso } },
    sort: 'data_inizio',
    limit: 3,
  }),
  fetchCollection<Progetto>('progetti', {
    sort: 'sort',
    limit: 3,
  }),
  fetchCollection<Evento>('eventi', {
    filter: { mostra_nella_home: { _eq: true } },
    sort: '-data_inizio',
    limit: 6,
  }),
  // Carosello home: solo foto della gallery flaggate `in_carosello_home`
  // sulla junction eventi_files. Espandiamo l'evento parent per ricavare
  // titolo (alt) e slug (link al dettaglio).
  fetchCollection<FotoCaroselloItem>('eventi_files', {
    fields: 'directus_files_id,eventi_id.titolo,eventi_id.slug',
    filter: { in_carosello_home: { _eq: true } },
    pubblicato: false,
    limit: 24,
  }),
  fetchCollection<Attivita>('attivita', { fields: 'UUID,slug', sort: 'sort' }),
]);

const slugAttivita: Record<string, string> = {};
for (const a of attivitaTutte) {
  if (a.UUID && a.slug) slugAttivita[a.UUID] = a.slug;
}

const fotoGallery = fotoCarosello
  .map((f) => {
    const url = assetUrl(f.directus_files_id);
    if (!url || !f.eventi_id) return null;
    return { url, titolo: f.eventi_id.titolo, slug: f.eventi_id.slug };
  })
  .filter((x): x is { url: string; titolo: string; slug: string } => x !== null);

const formattatoreDataBreve = new Intl.DateTimeFormat('it-IT', {
  day: 'numeric',
  month: 'long',
});
---

<Layout
  titolo="Home"
  descrizione="Crocevia dei Mondi APS: il gioco come strumento sociale, mondi che si incontrano nel Sud Italia."
  headerGrande
>
  <section class="hero">
    {heroEventi.length > 0 && (
      <ul role="list" class="hero__galleria">
        {heroEventi.map((e) => {
          const url = assetUrl(e.locandina);
          return (
            <li class="hero__slot">
              <a href={`/eventi/${e.slug}/`} class="hero__card">
                {url && (
                  <img
                    src={`${url}?width=900&height=600&fit=cover&format=jpg&quality=85`}
                    alt={e.titolo}
                    loading="eager"
                  />
                )}
                <div class="hero__overlay">
                  <time class="hero__data" datetime={e.data_inizio}>
                    {formattatoreDataBreve.format(new Date(e.data_inizio))}
                  </time>
                  <h2 class="hero__nome">{e.titolo}</h2>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}
    {fotoGallery.length > 0 && (
      <section class="banner-attivita" aria-label="Scopri le nostre attività">
        <ul role="list" class="banner-attivita__lista">
          {fotoGallery.map((f) => (
            <li class="banner-attivita__slide">
              <a href={`/eventi/${f.slug}/`} class="banner-attivita__link">
                <img
                  src={`${f.url}?width=1600&height=720&fit=cover&format=jpg&quality=82`}
                  alt={f.titolo}
                  loading="lazy"
                />
                <div class="banner-attivita__overlay">
                  <p class="banner-attivita__cta">Scopri le nostre attività</p>
                  <h2 class="banner-attivita__nome">{f.titolo}</h2>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </section>

  <section class="section">
    <div class="container">
      <header class="sezione-intestazione">
        <h2>Prossimi eventi</h2>
        <a href="/eventi/" class="sezione-intestazione__link">Tutti gli eventi →</a>
      </header>

      {prossimiEventi.length === 0 ? (
        <p class="sezione-vuota">
          Calendario in arrivo: appena pubblichiamo i prossimi appuntamenti li trovi qui.
        </p>
      ) : (
        <ul role="list" class="griglia-card">
          {prossimiEventi.map((evento) => (
            <li><CardEvento evento={evento} slugAttivita={slugAttivita} /></li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <header class="sezione-intestazione">
        <h2>Progetti in vetrina</h2>
        <a href="/progetti/" class="sezione-intestazione__link">Tutti i progetti →</a>
      </header>

      {progettiVetrina.length === 0 ? (
        <p class="sezione-vuota">
          Stiamo preparando la vetrina dei progetti attivi e di quelli realizzati.
        </p>
      ) : (
        <ul role="list" class="griglia-card">
          {progettiVetrina.map((progetto) => (
            <li><CardProgetto progetto={progetto} /></li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding-block: var(--space-8) var(--space-12);
  }

  /* Galleria orizzontale scrollabile, sfora il container fino al bordo viewport */
  .hero__galleria {
    list-style: none;
    margin: 0 0 var(--space-8);
    padding: 0 var(--gutter);
    display: flex;
    gap: var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    scrollbar-color: var(--color-accent) transparent;
    -webkit-overflow-scrolling: touch;
  }

  .hero__galleria::-webkit-scrollbar { height: 8px; }
  .hero__galleria::-webkit-scrollbar-thumb {
    background: var(--color-accent);
    border-radius: var(--radius-pill);
  }

  .hero__slot {
    flex: 0 0 auto;
    width: min(72vw, 540px);
    scroll-snap-align: start;
  }

  .hero__card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 2;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: color-mix(in srgb, var(--cdm-petrol) 15%, transparent);
    text-decoration: none;
    color: var(--color-on-dark);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--cdm-petrol) 18%, transparent);
    transition: transform 200ms ease;
  }

  .hero__card:hover {
    transform: translateY(-2px);
  }

  .hero__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: var(--space-6);
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--cdm-petrol) 92%, transparent) 0%,
      color-mix(in srgb, var(--cdm-petrol) 50%, transparent) 60%,
      transparent 100%
    );
    color: var(--color-on-dark);
  }

  .hero__data {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--cdm-orange-light);
  }

  .hero__nome {
    margin: var(--space-1) 0 0;
    font-size: var(--text-2xl);
    line-height: 1.15;
    color: var(--color-on-dark);
  }

  /* Banner full-width: foto curate (flag in_carosello_home) con CTA overlay.
     Click sulla slide -> dettaglio del singolo evento. */
  .banner-attivita {
    margin-top: var(--space-8);
  }

  .banner-attivita__lista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    scrollbar-color: var(--color-accent) transparent;
    -webkit-overflow-scrolling: touch;
  }

  .banner-attivita__lista::-webkit-scrollbar { height: 6px; }
  .banner-attivita__lista::-webkit-scrollbar-thumb {
    background: var(--color-accent);
    border-radius: var(--radius-pill);
  }

  .banner-attivita__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  .banner-attivita__link {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 7;
    max-height: 70vh;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-on-dark);
    background: color-mix(in srgb, var(--cdm-petrol) 15%, transparent);
  }

  .banner-attivita__link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .banner-attivita__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-12) var(--gutter) var(--space-10);
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--cdm-petrol) 88%, transparent) 0%,
      color-mix(in srgb, var(--cdm-petrol) 40%, transparent) 50%,
      transparent 100%
    );
  }

  .banner-attivita__cta {
    margin: 0 0 var(--space-2);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: var(--cdm-orange-light);
  }

  .banner-attivita__nome {
    margin: 0;
    font-size: var(--text-display);
    line-height: 1.05;
    color: var(--color-on-dark);
    text-shadow: 0 2px 12px color-mix(in srgb, var(--cdm-petrol) 60%, transparent);
  }

  @media (max-width: 640px) {
    .hero__nome { font-size: var(--text-xl); }
    .hero__slot { width: 84vw; }
    .banner-attivita__link {
      aspect-ratio: 4 / 5;
    }
    .banner-attivita__nome {
      font-size: var(--text-2xl);
    }
    .banner-attivita__overlay {
      padding: var(--space-8) var(--space-4) var(--space-6);
    }
  }

  .section--alt {
    background: color-mix(in srgb, var(--cdm-petrol) 6%, var(--color-bg));
  }

  .sezione-intestazione {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .sezione-intestazione__link {
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 600;
  }

  .sezione-vuota {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding: var(--space-8);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .griglia-card {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
