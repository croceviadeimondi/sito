---
import Layout from '../layouts/Layout.astro';
import { fetchSingleton } from '../lib/directus';
import type { Impostazioni } from '../lib/types';

const impostazioni = await fetchSingleton<Impostazioni>('impostazioni');
const codiceFiscale = impostazioni?.codice_fiscale ?? null;
const iban = impostazioni?.iban_donazioni ?? null;
const intestatario = impostazioni?.intestatario_iban ?? null;
const satispayUrl = impostazioni?.satispay_charity_url ?? null;
const messaggio = impostazioni?.messaggio_donazioni ?? null;
---

<Layout
  titolo="Sostienici"
  descrizione="Come sostenere il Crocevia dei Mondi APS: 5x1000, donazioni, tesseramento."
>
  <section class="hero">
    <span class="pip pip-a"></span><span class="pip pip-b"></span>
    <span class="pip pip-c"></span><span class="pip pip-d"></span>
    <div class="hero__in">
      <h1>Sostienici</h1>
      <p class="lede">
        Le nostre attività esistono e continuano a migliorare le nostre città
        grazie a chi crede in noi e nei nostri spazi. Ecco come potresti
        aiutarci anche tu.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {messaggio && <p class="messaggio">{messaggio}</p>}

      <div class="modi">

        <article class="modo modo--socio span-6">
          <h2>Diventa socio</h2>
          <p>
            Il modo migliore per sostenerci è esserci in prima fila. Le cose
            da fare sono molte e le competenze che ci mancano sono spesso
            quelle che tu hai. Tesserarsi è semplice, e ti garantisce benefit
            anche fuori dalle nostre sedi!
          </p>
          <a class="modo__btn" href="/tesserati/">Compila il modulo →</a>
        </article>

        <article class="modo modo--dona span-3">
          <h2>Fai una donazione</h2>
          <p>
            Anche una piccola donazione una tantum può aiutare a coprire i
            costi di materiali, trasferte, le sedi e i progetti timbrati
            Crocevia.
          </p>

          {iban && (
            <div class="evidenza">
              <span class="evidenza__etichetta">Bonifico bancario</span>
              <code>{iban}</code>
              {intestatario && (
                <small class="evidenza__intestatario">Intestato a: {intestatario}</small>
              )}
            </div>
          )}

          {satispayUrl && (
            <a class="modo__btn" href={satispayUrl} rel="noopener" target="_blank">
              Dona con Satispay →
            </a>
          )}

          {!iban && !satispayUrl && (
            <p class="nota">Le modalità saranno pubblicate qui a breve.</p>
          )}
        </article>

        <article class="modo modo--cinque span-3">
          <h2>Destina il 5×1000</h2>
          <p>
            Nella dichiarazione dei redditi, alla casella
            <em>"Sostegno del volontariato e delle altre organizzazioni non lucrative…"</em>,
            firma e indica il nostro codice fiscale.
          </p>
          {codiceFiscale ? (
            <div class="evidenza">
              <span class="evidenza__etichetta">Codice fiscale</span>
              <code>{codiceFiscale}</code>
            </div>
          ) : (
            <p class="nota">Il codice fiscale sarà pubblicato a breve.</p>
          )}
        </article>

      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---- hero a blocco pieno ---- */
  .hero {
    background: var(--cdm-petrol);
    color: var(--cdm-cream);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__in {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 84px var(--gutter) 80px;
    position: relative;
    z-index: 2;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 7vw, 5.4rem);
    font-weight: 800;
    line-height: 1.02;
    margin: 0;
    color: var(--cdm-cream);
  }
  .hero .lede {
    font-size: 1.25rem;
    margin-top: 18px;
    max-width: 52ch;
    color: color-mix(in srgb, var(--cdm-cream) 88%, transparent);
  }

  /* "galassia" della pagina sostienici */
  .pip { position: absolute; border-radius: 50%; z-index: 1; }
  .pip-a { width: 90px; height: 90px; background: var(--cdm-orange); top: 48px; right: 64px; }
  .pip-b {
    width: 230px; height: 230px; top: -80px; right: 170px;
    border: 3px solid color-mix(in srgb, var(--cdm-orange-light) 34%, transparent);
  }
  .pip-c {
    width: 150px; height: 150px; top: 124px; right: -52px;
    background: color-mix(in srgb, var(--cdm-cobalt) 85%, transparent);
  }
  .pip-d { width: 44px; height: 44px; background: var(--cdm-orange-light); top: 172px; right: 214px; }

  .messaggio {
    max-width: 60ch;
    margin: 0 auto var(--space-12);
    font-size: var(--text-lg);
    text-align: center;
  }

  /* ---- tessere ---- */
  .modi {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-6);
  }
  .span-6 { grid-column: span 6; }
  .span-3 { grid-column: span 3; }

  .modo {
    border-radius: 22px;
    padding: var(--space-8);
    color: #fff;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .modo--socio { background: var(--cdm-cobalt); }
  .modo--dona { background: var(--cdm-orange); }
  .modo--cinque { background: var(--cdm-navy); }

  .modo h2 {
    margin: 0;
    font-size: var(--text-2xl);
  }
  .modo p {
    margin: 0;
    max-width: 58ch;
  }
  .modo em { font-style: italic; }
  /* allinea in basso l'ultimo elemento (CTA/box) cosi' le tessere affiancate combaciano */
  .modo > :last-child { margin-top: auto; }

  .modo__btn {
    align-self: flex-start;
    background: #fff;
    color: var(--cdm-petrol);
    font-weight: 700;
    padding: 11px 20px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: transform 150ms ease;
  }
  .modo__btn:hover { transform: translateY(-2px); }

  .evidenza {
    background: rgba(255, 255, 255, 0.14);
    border-radius: 12px;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .evidenza__etichetta {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
  }
  .evidenza code {
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.04em;
    font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
    word-break: break-all;
  }
  .evidenza__intestatario {
    color: rgba(255, 255, 255, 0.75);
    font-style: italic;
    font-size: var(--text-sm);
  }

  .nota {
    margin: 0;
    color: rgba(255, 255, 255, 0.8);
    font-style: italic;
  }

  /* sotto gli 820px: una colonna sola */
  @media (max-width: 820px) {
    .modi { grid-template-columns: 1fr; }
    .span-6, .span-3 { grid-column: auto; }
  }
</style>
