---
import { fetchSingleton, fetchCollection } from '../lib/directus';
import type { Impostazioni, Sede } from '../lib/types';

const [impostazioni, sediLegali] = await Promise.all([
  fetchSingleton<Impostazioni>('impostazioni'),
  fetchCollection<Sede>('sedi', {
    fields: 'id,nome,is_sede_legale,citta,indirizzo_completo',
    filter: { is_sede_legale: { _eq: true } },
    limit: 1,
  }),
]);
const sedeLegale = sediLegali[0] ?? null;
const annoCorrente = new Date().getFullYear();

const denominazione = impostazioni?.denominazione_completa ?? 'Crocevia dei Mondi APS';
const codiceFiscale = impostazioni?.codice_fiscale ?? null;
const partitaIva = impostazioni?.partita_iva ?? null;
const runts = impostazioni?.numero_runts ?? null;
const emailPubblica = impostazioni?.email_principale ?? null;
const tagline = impostazioni?.tagline
  ?? 'Il gioco come strumento sociale. Mondi che si incontrano nel Sud Italia.';
const testoFooter = impostazioni?.testo_footer ?? null;

const indirizzoSede = sedeLegale?.indirizzo_completo ?? null;
const cittaSede = sedeLegale?.citta ?? null;
---

<footer class="footer">
  <div class="container footer__griglia">
    <div class="footer__brand">
      <span class="footer__marchio">Crocevia dei Mondi</span>
      <p class="footer__payoff">{tagline}</p>
      {emailPubblica && (
        <p class="footer__contatto">
          <a href={`mailto:${emailPubblica}`}>{emailPubblica}</a>
        </p>
      )}
    </div>

    <nav class="footer__nav" aria-label="Approfondisci">
      <h2 class="footer__titolo">Approfondisci</h2>
      <ul role="list">
        <li><a href="/tesserati/">Tesseramento</a></li>
        <li><a href="/sedi/">Le nostre sedi</a></li>
        <li><a href="/partner/">Partner e collaborazioni</a></li>
        <li><a href="/parlano-di-noi/">Parlano di noi</a></li>
        <li><a href="/trasparenza/">Trasparenza</a></li>
        <li><a href="/privacy/">Privacy &amp; cookie</a></li>
      </ul>
    </nav>

    <div class="footer__istituzionale">
      <h2 class="footer__titolo">Dati istituzionali</h2>
      <address>
        <strong>{denominazione}</strong>
        {indirizzoSede && (
          <><br />Sede legale: {indirizzoSede}{cittaSede && ` (${cittaSede})`}</>
        )}
        {codiceFiscale && <><br />C.F. {codiceFiscale}</>}
        {partitaIva && <><br />P.IVA {partitaIva}</>}
        {runts && <><br />RUNTS n. {runts}</>}
      </address>
      {testoFooter && <p class="footer__testo-libero">{testoFooter}</p>}
    </div>
  </div>

  <div class="footer__copyright">
    <div class="container">
      <small>&copy; {annoCorrente} {denominazione} - Tutti i diritti riservati</small>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface-dark);
    color: var(--color-on-dark);
    margin-top: var(--space-24);
  }

  .footer a {
    color: var(--color-on-dark);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 150ms ease;
  }

  .footer a:hover {
    color: var(--color-on-dark);
    border-bottom-color: var(--cdm-orange-light);
  }

  .footer__griglia {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1.4fr;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  .footer__marchio {
    font-family: var(--font-logo);
    font-size: var(--text-2xl);
    color: var(--cdm-orange-light);
    display: block;
    margin-bottom: var(--space-3);
  }

  .footer__logo {
    display: block;
    height: 3.5rem;
    width: auto;
    object-fit: contain;
    margin-bottom: var(--space-3);
  }

  .footer__payoff {
    color: color-mix(in srgb, var(--color-on-dark) 85%, transparent);
    max-width: 28ch;
    margin-bottom: var(--space-3);
  }

  .footer__contatto {
    font-size: var(--text-sm);
  }

  .footer__titolo {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
    color: var(--cdm-orange-light);
  }

  .footer__nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__istituzionale address {
    font-style: normal;
    line-height: 1.8;
  }

  .footer__testo-libero {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--color-on-dark) 80%, transparent);
  }

  .footer__copyright {
    border-top: 1px solid color-mix(in srgb, var(--color-on-dark) 15%, transparent);
    padding-block: var(--space-4);
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--color-on-dark) 70%, transparent);
  }

  @media (max-width: 820px) {
    .footer__griglia {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
