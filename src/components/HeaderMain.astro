---
import { fetchSingleton, assetUrl } from '../lib/directus';
import type { Impostazioni } from '../lib/types';

interface Props {
  /** Non più usato: l'header è identico su tutte le pagine. Accettato per
   *  compatibilità con Layout. */
  grande?: boolean;
}

const impostazioni = await fetchSingleton<Impostazioni>('impostazioni');
const urlLogo = assetUrl(impostazioni?.logo_principale);
const pathCorrente = Astro.url.pathname.replace(/\/$/, '') || '/';

const voci: { etichetta: string; href: string }[] = [
  { etichetta: 'Chi siamo', href: '/chi-siamo/' },
  { etichetta: 'Attività', href: '/attivita/' },
  { etichetta: 'Progetti', href: '/progetti/' },
  { etichetta: 'Eventi', href: '/eventi/' },
  { etichetta: 'Sostienici', href: '/sostienici/' },
  { etichetta: 'Contatti', href: '/contatti/' },
];

function attiva(href: string): boolean {
  if (href === '/') return pathCorrente === '/';
  const hrefNoSlash = href.replace(/\/$/, '');
  return pathCorrente === hrefNoSlash || pathCorrente.startsWith(hrefNoSlash + '/');
}
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__brand" aria-label="Crocevia dei Mondi - home">
      {urlLogo ? (
        <img src={urlLogo} alt="" class="header__logo" />
      ) : (
        <span class="header__brand-mark">CdM</span>
      )}
      <span class="header__brand-name">Crocevia dei Mondi</span>
    </a>

  </div>

  <button
    class="header__toggle"
    type="button"
    aria-expanded="false"
    aria-controls="menu-principale"
  >
    <span class="header__toggle-icon" aria-hidden="true"></span>
    <span class="header__toggle-testo">Menu</span>
  </button>

  <nav class="header__nav" id="menu-principale" aria-label="Navigazione principale">
    <ul role="list" class="header__nav-list">
      {voci.map((voce) => (
        <li>
          <a
            href={voce.href}
            class:list={['header__link', { 'is-attivo': attiva(voce.href) }]}
            aria-current={attiva(voce.href) ? 'page' : undefined}
          >
            {voce.etichetta}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>('.header');
  if (header) {
    const toggle = header.querySelector<HTMLButtonElement>('.header__toggle');
    const nav = header.querySelector<HTMLElement>('.header__nav');

    if (toggle && nav) {
      const setMenu = (aperto: boolean) => {
        header.classList.toggle('menu-aperto', aperto);
        toggle.setAttribute('aria-expanded', String(aperto));
      };
      toggle.addEventListener('click', () => {
        setMenu(!header.classList.contains('menu-aperto'));
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && header.classList.contains('menu-aperto')) {
          setMenu(false);
          toggle.focus();
        }
      });
      nav.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => setMenu(false))
      );
    }
  }
</script>

<style>
  .header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(180%) blur(8px);
  }

  /* brand centrato, toggle ancorato a destra */
  .header__inner {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    padding-block: var(--space-4);
  }

  .header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-accent);
    font-family: var(--font-logo);
  }

  .header__brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-accent);
    color: var(--color-on-dark);
    border-radius: var(--radius-pill);
    font-size: 0.875rem;
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .header__brand-name {
    font-size: clamp(1.5rem, 5vw, 3rem);
    color: var(--color-accent);
    line-height: 1;
  }

  .header__logo {
    display: block;
    height: clamp(2rem, 5vw, 2.8rem);
    width: auto;
    object-fit: contain;
  }

  /* toggle hamburger: sempre visibile */
  .header__toggle {
    position: absolute;
    right: var(--gutter);
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 2.75rem;
    padding: 0 var(--space-3);
    background: transparent;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md);
    color: var(--color-accent);
    cursor: pointer;
  }

  .header__toggle-testo {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .header__toggle:hover {
    background: color-mix(in srgb, var(--cdm-orange) 8%, transparent);
  }

  .header__toggle-icon,
  .header__toggle-icon::before,
  .header__toggle-icon::after {
    display: block;
    width: 1.25rem;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
  }

  .header__toggle-icon {
    position: relative;
    transition: background-color 150ms ease;
  }

  .header__toggle-icon::before,
  .header__toggle-icon::after {
    content: '';
    position: absolute;
    left: 0;
    transition: transform 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .header__toggle-icon::before { top: -0.4rem; }
  .header__toggle-icon::after  { top:  0.4rem; }

  .header.menu-aperto .header__toggle-icon {
    background: transparent;
  }
  .header.menu-aperto .header__toggle-icon::before {
    transform: translateY(0.4rem) rotate(45deg);
  }
  .header.menu-aperto .header__toggle-icon::after {
    transform: translateY(-0.4rem) rotate(-45deg);
  }

  /* nav: tendina a tutta larghezza sotto l'header */
  .header__nav {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-2) var(--gutter) var(--space-4);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--cdm-petrol) 12%, transparent);

    visibility: hidden;
    opacity: 0;
    transform: translateY(-8px);
    transition:
      visibility 200ms,
      opacity 200ms ease,
      transform 200ms ease;
  }

  .header.menu-aperto .header__nav {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
  }

  .header__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .header__link {
    display: block;
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-lg);
    font-weight: 600;
    text-align: right;
    padding: var(--space-3) var(--space-1);
    border-bottom: 1px solid var(--color-border);
    transition: color 120ms ease;
  }

  .header__nav-list li:last-child .header__link {
    border-bottom: 0;
  }

  .header__link:hover {
    color: var(--color-accent);
  }

  .header__link.is-attivo {
    color: var(--color-accent);
  }

  /* su schermi stretti (cellulare / viewport molto verticale) resta
     solo l'icona hamburger, senza la scritta "Menu" */
  @media (max-width: 600px) {
    .header__toggle-testo {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header__nav,
    .header__toggle-icon::before,
    .header__toggle-icon::after {
      transition: none;
    }
  }
</style>
