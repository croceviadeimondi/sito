---
const pathCorrente = Astro.url.pathname.replace(/\/$/, '') || '/';

const voci: { etichetta: string; href: string }[] = [
  { etichetta: 'Chi siamo', href: '/chi-siamo' },
  { etichetta: 'Cosa facciamo', href: '/cosa-facciamo' },
  { etichetta: 'Progetti', href: '/progetti' },
  { etichetta: 'Eventi', href: '/eventi' },
  { etichetta: 'Sostienici', href: '/sostienici' },
  { etichetta: 'Contatti', href: '/contatti' },
];

function attiva(href: string): boolean {
  if (href === '/') return pathCorrente === '/';
  return pathCorrente === href || pathCorrente.startsWith(href + '/');
}
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__brand" aria-label="Crocevia dei Mondi — home">
      <span class="header__brand-mark">CdM</span>
      <span class="header__brand-name">Crocevia dei Mondi</span>
    </a>

    <nav class="header__nav" aria-label="Navigazione principale">
      <ul role="list" class="header__nav-list">
        {voci.map((voce) => (
          <li>
            <a
              href={voce.href}
              class:list={['header__link', { 'is-attivo': attiva(voce.href) }]}
              aria-current={attiva(voce.href) ? 'page' : undefined}
            >
              {voce.etichetta}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(180%) blur(8px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-4);
  }

  .header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-accent);
    font-family: var(--font-logo);
  }

  .header__brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--color-accent);
    color: var(--color-on-dark);
    border-radius: var(--radius-pill);
    font-size: 0.875rem;
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .header__brand-name {
    font-size: var(--text-2xl);
    color: var(--color-accent);
    line-height: 1;
  }

  .header__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .header__link {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-base);
    padding-block: var(--space-2);
    position: relative;
  }

  .header__link:hover {
    color: var(--color-accent);
  }

  .header__link.is-attivo {
    color: var(--color-accent);
    font-weight: 600;
  }

  .header__link.is-attivo::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--color-accent);
    border-radius: var(--radius-pill);
  }

  @media (max-width: 820px) {
    .header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }

    .header__brand-name {
      font-size: var(--text-xl);
    }
  }
</style>
